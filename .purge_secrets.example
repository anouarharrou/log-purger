# ─────────────────────────────────────────────────────────────────────────────
# .purge_secrets — SMTP credentials template
#
# USAGE:
#   cp .purge_secrets.example .purge_secrets
#   chmod 600 .purge_secrets
#   nano .purge_secrets     # fill in your values
#
# This file is sourced by purge_crontab.sh at runtime.
# .purge_secrets is in .gitignore — NEVER commit it with real values.
# ─────────────────────────────────────────────────────────────────────────────

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""          # your Gmail address or SMTP username
SMTP_PASS=""          # Gmail app-password (NOT your account password)
MAIL_FROM=""          # sender address (defaults to SMTP_USER if empty)
MAIL_TO=""            # comma-separated recipients: "a@x.com,b@x.com"
