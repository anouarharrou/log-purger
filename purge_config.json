{
    "config": {
        "bucket": "bucket",
        "key": "aws key",
        "secret": "aws secret",
        "server": "s3.{region}.amazonaws.com",
        "project": "project name"
    },
    "services": [
        {
            "service": "application name",
            "log_path": "../logs",
            "pattern": "^service.log-.+",
            "compress": "true",
            "RemoveOnTransfer": "true"
        }
    ]
  }